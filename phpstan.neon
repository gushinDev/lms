parameters:
    level: max
    paths:
        - app
        - database
    ignoreErrors:
        - '#Property Illuminate\\\\Foundation\\\\Application::\$basePath not found#'
        - '#Call to an undefined method Illuminate\\\\Database\\\\Query\\\\Builder::getResults()#'
    excludes_analyse:
        - */vendor/**
        - */tests/**
        - */database/**
